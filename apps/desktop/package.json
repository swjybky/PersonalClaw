{
  "name": "@personal-claw/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "smoke": "PERSONAL_CLAW_SMOKE=1 electron-vite preview",
    "smoke:renderer": "PERSONAL_CLAW_RENDERER_SMOKE=1 electron-vite preview"
  },
  "dependencies": {
    "@personal-claw/application": "workspace:*",
    "@personal-claw/chat-ui-adapter": "workspace:*",
    "@personal-claw/contracts": "workspace:*",
    "@personal-claw/shared": "workspace:*",
    "naive-ui": "2.44.1",
    "pinia": "3.0.4",
    "vue": "3.5.39"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "typescript": "6.0.3",
    "vite": "8.1.0",
    "vue-tsc": "3.3.5"
  },
  "build": {
    "appId": "com.personalclaw.desktop",
    "productName": "PersonalClaw",
    "directories": {
      "output": "release"
    },
    "icon": "resources/icon.png",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": ["*.png"]
      }
    ],
    "linux": {
      "icon": "resources/icon.png"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.png"
    }
  }
}
